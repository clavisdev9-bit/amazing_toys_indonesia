# =============================================================================
# Amazing Toys SOS — Environment Configuration
# Copy this file to .env and fill in values
# =============================================================================

# App
NODE_ENV=development
PORT=3000
APP_NAME=AmazingToysSOS

# Database — PostgreSQL
DB_HOST=localhost
DB_PORT=3452
DB_NAME=amazing_toys_sos
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Customer Session (phone-based, shorter token)
CUSTOMER_TOKEN_EXPIRES_IN=24h

# Transaction
TXN_PENDING_TIMEOUT_MINUTES=30

# QR Code
QR_CODE_BASE_URL=http://localhost:3000/api/v1/transactions

# Payment Gateway (mock in development)
PAYMENT_GATEWAY_URL=https://sandbox.payment-gateway.id/api
PAYMENT_GATEWAY_KEY=sandbox_key_here
PAYMENT_GATEWAY_SECRET=sandbox_secret_here

# Thermal Printer (ESC/POS via TCP)
# Set PRINTER_IP to the printer's network IP (e.g., 192.168.1.100)
# Leave blank to disable direct print (browser print will be used as fallback)
PRINTER_IP=
PRINTER_PORT=9100

# Push Notifications (FCM)
FCM_SERVER_KEY=your_fcm_server_key_here
FCM_PROJECT_ID=your_firebase_project_id

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Odoo 18 Integration Service (FSD-AMZTOYS-2026-001)
# Set to integration service webhook base URL when running the integration service
INTEGRATION_WEBHOOK_URL=http://localhost:4000
# Shared secret for X-SOS-Signature header validation (must match integration WEBHOOK_SECRET)
WEBHOOK_SECRET=

# ── BCA QRIS MPM Integration ──────────────────────────────────────────────────
# These can also be configured via Admin → Integrasi → BCA QRIS (stored in DB)
# Env vars take precedence over DB config.
BCA_ENV=sandbox
BCA_BASE_URL=https://sandbox.bca.co.id
# OAuth Credentials
BCA_CLIENT_ID=
BCA_CLIENT_SECRET=
# API Credentials
BCA_API_KEY=
BCA_API_SECRET=
# Merchant Info
BCA_MERCHANT_ID=
BCA_TERMINAL_ID=
BCA_CHANNEL_ID=
# Callback / Webhook URL (must be publicly reachable HTTPS)
BCA_CALLBACK_URL=
# Token cache TTL in seconds (default 840 = 900s expire - 60s buffer)
BCA_TOKEN_TTL=840
