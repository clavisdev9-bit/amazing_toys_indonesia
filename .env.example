# ── Copy this file to .env and fill in the values ──────────────────────────
# cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_min_64_chars_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=8h
CUSTOMER_TOKEN_EXPIRES_IN=24h

# ── Webhook shared secret (backend ↔ integration) ─────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change_me_webhook_secret_hex

# ── Transaction ───────────────────────────────────────────────────────────────
TXN_PENDING_TIMEOUT_MINUTES=30

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
# Set to your server's public URL, e.g. https://amazingtoys.example.com
CORS_ORIGIN=http://localhost

# ── Frontend port on the host ─────────────────────────────────────────────────
FRONTEND_PORT=80

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use a Gmail App Password, NOT your account password
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Amazing Toys SOS <your-email@gmail.com>"
EMAIL_NOTIFY_TO=your-email@gmail.com

# ── Thermal Printer (ESC/POS over TCP, optional) ─────────────────────────────
# PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# ── Integration service — SOS admin account ───────────────────────────────────
SOS_ADMIN_USERNAME=integration_admin
SOS_ADMIN_PASSWORD=changeme

# ── Odoo 18 ───────────────────────────────────────────────────────────────────
ODOO_BASE_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your_odoo_db
ODOO_LOGIN=admin
ODOO_PASSWORD=changeme
ODOO_WALKIN_PARTNER_ID=

# ── Odoo sync thresholds (optional — defaults shown) ─────────────────────────
LOW_STOCK_THRESHOLD=10
PRODUCT_SYNC_INTERVAL_MIN=30
STOCK_SYNC_INTERVAL_MIN=30
SWEEP_INTERVAL_MIN=5
POLLING_INTERVAL_SEC=60
RETRY_MAX_ATTEMPTS=3
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MIN=2

# ── Tenant mapping (JSON string, optional) ────────────────────────────────────
TENANT_PRODUCT_MAPPING={}
DEFAULT_TENANT_ID=T001
