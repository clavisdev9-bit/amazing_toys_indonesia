# ── Integration Service (FSD-AMZTOYS-2026-001) ────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── SOS API ───────────────────────────────────────────────────────────────────
SOS_BASE_URL=http://localhost:3000/api/v1
SOS_ADMIN_USERNAME=integration_admin
SOS_ADMIN_PASSWORD=

# ── Odoo 18 ───────────────────────────────────────────────────────────────────
ODOO_BASE_URL=http://localhost:8069
ODOO_DB=odoo18
ODOO_LOGIN=admin
ODOO_PASSWORD=

# ── Odoo Fallback Partner ─────────────────────────────────────────────────────
# Integer ID of the "Walk-in Customer" res.partner in Odoo
ODOO_WALKIN_PARTNER_ID=

# ── Webhook Security ──────────────────────────────────────────────────────────
# Shared secret between SOS and integration service for X-SOS-Signature header
WEBHOOK_SECRET=

# ── xref/Audit Database ───────────────────────────────────────────────────────
# Reuses the SOS PostgreSQL database (port 3452)
XREF_DB_URL=postgresql://postgres:password@localhost:3452/amazing_toys_sos

# ── Sync Thresholds (all optional — defaults shown) ───────────────────────────
LOW_STOCK_THRESHOLD=10
PRODUCT_SYNC_INTERVAL_MIN=30
STOCK_SYNC_INTERVAL_MIN=30
SWEEP_INTERVAL_MIN=5
POLLING_INTERVAL_SEC=60
RETRY_MAX_ATTEMPTS=3
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MIN=2

# ── Tenant mapping: Odoo product category name → SOS tenant_id ───────────────
# JSON object string. e.g. {"Hasbro": "T001", "Lego": "T002"}
# Used when creating new SOS products from Odoo catalogue (FR-002)
TENANT_PRODUCT_MAPPING={}

# ── Default SOS tenant for unmapped Odoo products ─────────────────────────────
DEFAULT_TENANT_ID=T001
